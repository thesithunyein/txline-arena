{
  "name": "txline-arena",
  "version": "0.1.0",
  "description": "TxLINE Arena — Autonomous in-play trading agent platform with on-chain settlement on Solana",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "dev": "cross-env ENV_FILE=.env ts-node src/index.ts",
    "subscribe": "cross-env ENV_FILE=.env ts-node scripts/subscribe.ts",
    "activate": "cross-env ENV_FILE=.env ts-node scripts/activate.ts",
    "settle-onchain": "cross-env ENV_FILE=.env ts-node scripts/settle-onchain.ts",
    "backtest": "cross-env ENV_FILE=.env ts-node scripts/backtest.ts",
    "test": "jest --verbose"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.4",
    "axios": "^1.7.7",
    "lowdb": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "node-telegram-bot-api": "^0.66.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.14.0",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/ws": "^8.5.12",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  }
}
