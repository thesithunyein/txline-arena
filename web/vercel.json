{
  "framework": "nextjs",
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/health",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "https://thesithunyein-txline-arena-api.hf.space/health"
    },
    {
      "source": "/api/:path*",
      "destination": "https://thesithunyein-txline-arena-api.hf.space/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://thesithunyein-txline-arena-api.hf.space/health"
    }
  ]
}
